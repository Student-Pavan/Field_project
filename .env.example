# =============================================================================
# Cable Automation Workflow Simulator — Root Environment Variables
# Copy to .env and adjust values for your environment.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=cable_sim
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=cable_automation
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Backend (FastAPI) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=false
SECRET_KEY=change_me_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000

# --- Simulation (SimPy) ---
SIMULATION_DEFAULT_TICK_MS=100
SIMULATION_MAX_CONCURRENT=10

# --- Docker Compose ---
COMPOSE_PROJECT_NAME=cable-automation-simulator
